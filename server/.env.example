# Server configuration
PORT=5000
NODE_ENV=development

# Gemini API Key (Required for primary AI processing)
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini Model Selection (e.g. gemini-2.5-flash)
# Defaults to gemini-2.5-flash for the optimal balance of speed, 1M context, and 15 RPM rate limits.
GEMINI_MODEL=gemini-2.5-flash

# Security
# Set this to your frontend URL in production (e.g. https://lead-mapper.vercel.app)
ALLOWED_ORIGIN=http://localhost:3000
